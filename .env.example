# Metra GTFS-Realtime API bearer token (from gtfspublic.metrarr.com)
METRA_TOKEN=

# Resolved via: wall-dashboard stations Northbrook (and same for Chicago Union Station)
NORTHBROOK_STOP_ID=
CUS_STOP_ID=

# Northbrook lat/lon for NWS + Open-Meteo (already correct defaults)
NWS_LAT=42.1275
NWS_LON=-87.8290

# Required by NWS terms of service (must identify your app + contact)
NWS_USER_AGENT=wall-dashboard your-email@example.com

# Populated by: wall-dashboard bootstrap-nws  (on first run)
NWS_FORECAST_HOURLY_URL=

# Display window for weather "rest of today" vs "tomorrow" flip
WEATHER_FLIP_HOUR=17
WEATHER_END_HOUR=21
